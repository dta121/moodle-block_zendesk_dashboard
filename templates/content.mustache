  @template block_zendesk_dashboard/content

  Example context (json):
  {
    "dashboardintro": "Create a new request or review your latest support updates.",
    "newrequesturl": "#",
    "newrequestlabel": "New request",
    "hashelpcenterlink": true,
    "helpcenterurl": "#",
    "helpcenterlabel": "Open Help Center",
    "tabuid": "zendesk-tabs-demo",
    "activetablabel": "Active",
    "activecount": 2,
    "historytablabel": "History",
    "historycount": 4,
    "allrequestsurl": "#",
    "allrequestslabel": "All requests",
    "hasactiverequests": true,
    "activerequests": [
      {
        "viewurl": "#",
        "subject": "Testing Plugin for Moodle",
        "statuspillclass": "block-zendesk-dashboard__status-pill block-zendesk-dashboard__status-pill--open",
        "statuslabel": "Open",
        "hascourse": true,
        "coursefullname": "Student Success 101",
        "timemodifiedhuman": "Updated 2 hours ago"
      }
    ],
    "hashistoryrequests": true,
    "historyrequests": [
      {
        "viewurl": "#",
        "subject": "Resolved sign-in issue",
        "statuspillclass": "block-zendesk-dashboard__status-pill block-zendesk-dashboard__status-pill--solved",
        "statuslabel": "Solved",
        "hascourse": false,
        "timemodifiedhuman": "Updated yesterday"
      }
    ],
    "noactiverequests": "No active requests",
    "activeemptyhelp": "Everything is caught up. Create a new request if you need help.",
    "nohistoryrequests": "No resolved or closed requests yet."
  }
}}

<div class="block-zendesk-dashboard">
    <div class="block-zendesk-dashboard__panel">
        <div class="block-zendesk-dashboard__intro">
            <p class="block-zendesk-dashboard__summary">{{dashboardintro}}</p>
        </div>

        <div class="block-zendesk-dashboard__actions">
            <a class="block-zendesk-dashboard__action block-zendesk-dashboard__action--primary" href="{{newrequesturl}}">
                <span class="block-zendesk-dashboard__action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                    </svg>
                </span>
                <span>{{newrequestlabel}}</span>
            </a>
            {{#hashelpcenterlink}}
            <a class="block-zendesk-dashboard__action block-zendesk-dashboard__action--secondary" href="{{helpcenterurl}}">
                <span class="block-zendesk-dashboard__action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="2"/>
                        <path d="M12 4v4M12 16v4M4 12h4M16 12h4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2"/>
                    </svg>
                </span>
                <span>{{helpcenterlabel}}</span>
            </a>
            {{/hashelpcenterlink}}
        </div>

        <input class="block-zendesk-dashboard__tab-input block-zendesk-dashboard__tab-input--active" type="radio" name="{{tabuid}}" id="{{tabuid}}-active" checked>
        <input class="block-zendesk-dashboard__tab-input block-zendesk-dashboard__tab-input--history" type="radio" name="{{tabuid}}" id="{{tabuid}}-history">

        <div class="block-zendesk-dashboard__tabs-head">
            <div class="block-zendesk-dashboard__tabs">
                <label class="block-zendesk-dashboard__tab block-zendesk-dashboard__tab--active" for="{{tabuid}}-active">
                    <span>{{activetablabel}}</span>
                    <span class="block-zendesk-dashboard__count">{{activecount}}</span>
                </label>
                <label class="block-zendesk-dashboard__tab block-zendesk-dashboard__tab--history" for="{{tabuid}}-history">
                    <span>{{historytablabel}}</span>
                    <span class="block-zendesk-dashboard__count">{{historycount}}</span>
                </label>
            </div>
            <a class="block-zendesk-dashboard__all-link" href="{{allrequestsurl}}">{{allrequestslabel}}</a>
        </div>

        <div class="block-zendesk-dashboard__tab-panels">
            <section class="block-zendesk-dashboard__tab-panel block-zendesk-dashboard__tab-panel--active">
                {{#hasactiverequests}}
                <div class="block-zendesk-dashboard__list">
                    {{#activerequests}}
                    <article class="block-zendesk-dashboard__ticket">
                        <div class="block-zendesk-dashboard__ticket-head">
                            <a class="block-zendesk-dashboard__ticket-title" href="{{viewurl}}">{{subject}}</a>
                            <span class="{{statuspillclass}}">{{statuslabel}}</span>
                        </div>
                        {{#hascourse}}
                        <div class="block-zendesk-dashboard__ticket-context">{{coursefullname}}</div>
                        {{/hascourse}}
                        <div class="block-zendesk-dashboard__ticket-meta">{{timemodifiedhuman}}</div>
                    </article>
                    {{/activerequests}}
                </div>
                {{/hasactiverequests}}

                {{^hasactiverequests}}
                <div class="block-zendesk-dashboard__empty block-zendesk-dashboard__empty--celebratory">
                    <div class="block-zendesk-dashboard__empty-title">{{noactiverequests}}</div>
                    <div class="block-zendesk-dashboard__empty-copy">{{activeemptyhelp}}</div>
                    <a class="block-zendesk-dashboard__empty-link" href="{{newrequesturl}}">{{newrequestlabel}}</a>
                </div>
                {{/hasactiverequests}}
            </section>

            <section class="block-zendesk-dashboard__tab-panel block-zendesk-dashboard__tab-panel--history">
                {{#hashistoryrequests}}
                <div class="block-zendesk-dashboard__list">
                    {{#historyrequests}}
                    <article class="block-zendesk-dashboard__ticket">
                        <div class="block-zendesk-dashboard__ticket-head">
                            <a class="block-zendesk-dashboard__ticket-title" href="{{viewurl}}">{{subject}}</a>
                            <span class="{{statuspillclass}}">{{statuslabel}}</span>
                        </div>
                        {{#hascourse}}
                        <div class="block-zendesk-dashboard__ticket-context">{{coursefullname}}</div>
                        {{/hascourse}}
                        <div class="block-zendesk-dashboard__ticket-meta">{{timemodifiedhuman}}</div>
                    </article>
                    {{/historyrequests}}
                </div>
                {{/hashistoryrequests}}

                {{^hashistoryrequests}}
                <div class="block-zendesk-dashboard__empty">{{nohistoryrequests}}</div>
                {{/hashistoryrequests}}
            </section>
        </div>
    </div>
</div>
